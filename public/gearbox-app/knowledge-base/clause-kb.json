    {
      "id": "pump-001",
      "category": "pump",
      "title": "液压泵型号规格",
      "content": "液压泵采用高压柱塞泵，额定工作压力不低于25MPa，峰值压力不低于31.5MPa。流量应满足系统设计要求，容积效率不低于92%。",
      "keywords": ["液压泵", "柱塞泵", "压力", "流量", "容积效率"],
      "applicableSeries": ["HC", "HCD", "GWC", "GWS"],
      "variants": [
        { "condition": "功率>500kW", "text": "采用双联泵结构，主泵与辅助泵独立驱动" },
        { "condition": "功率≤200kW", "text": "采用单泵结构，配备溢流阀保护" }
      ],
      "references": ["GB/T 7935", "ISO 4409"],
      "lastUsed": "2025-12-15"
    },
    {
      "id": "pump-002",
      "category": "pump",
      "title": "液压泵安装要求",
      "content": "液压泵应采用弹性联轴器与原动机连接，同轴度偏差不大于0.05mm。泵的吸油管路应短而直，吸油高度不超过500mm，吸油管内径应保证油液流速不超过1.5m/s。",
      "keywords": ["液压泵", "安装", "联轴器", "同轴度", "吸油管"],
      "applicableSeries": ["HC", "HCD", "HCT", "GWC"],
