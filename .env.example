# 齿轮箱选型系统 - 环境变量配置模板
# 复制此文件为 .env.local 并填入实际值

# ===========================================
# 认证配置 (密码哈希值)
# ===========================================
# 使用 SHA-256 哈希存储密码
# 生成方法: echo -n "your_password" | sha256sum
# 或使用 Node.js: require('crypto').createHash('sha256').update('password').digest('hex')

# 管理员密码哈希
REACT_APP_ADMIN_HASH=your_admin_password_sha256_hash_here

# 普通用户密码哈希
REACT_APP_USER_HASH=your_user_password_sha256_hash_here
